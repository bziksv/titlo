# Локальный порт Next (dev/start/docker)
PORT=3001

# Аналитика (ID с live redbox.su / Kraken JS)
NEXT_PUBLIC_YM_ID=54591493
# NEXT_PUBLIC_GA_ID=

# Публичный URL маркетингового сайта (robots, sitemap, canonical)
NEXT_PUBLIC_SITE_URL=https://titlo.ru

# Публичный URL кабинета (кнопки «Вход», «Регистрация»)
NEXT_PUBLIC_LK_URL=https://cabinet.titlo.ru

# База API Laravel для BFF-прокси (только сервер Next)
LK_API_BASE_URL=https://cabinet.titlo.ru
# Локально для fallback demo (анализ текста → cabinet :3002)
# CABINET_DEMO_API_URL=http://127.0.0.1:3002

# Форма «Задать вопрос» — письма на info@titlo.ru и sv6@list.ru (см. CONTACT_TO)
# SMTP (обязательно для отправки писем)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-login
SMTP_PASS=your-password
SMTP_FROM=noreply@titlo.ru

# Получатели (через запятую; по умолчанию info@titlo.ru, sv6@list.ru)
# CONTACT_TO=info@titlo.ru,sv6@list.ru

# Опционально: webhook или lk, если SMTP не используется
# CONTACT_WEBHOOK_URL=https://hooks.example.com/contact
